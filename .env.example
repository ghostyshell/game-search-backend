# game-search-backend env (copy to .env; never commit .env)

# Server
PORT=3011

# MongoDB (shared Sliplane Mongo; backend owns games_* collections)
MONGODB_URI=mongodb://localhost:27017
MONGO_USERNAME=
MONGO_PASSWORD=
MONGODB_DB=gamesearch

# Metadata enrichment (you supply)
RAWG_API_KEY=
THEGAMESDB_API_KEY=

# Debrid host sync (both endpoints are public, no key needed)
# TorBox: https://api.torbox.app/api/v1/api/webdl/hosters (and /hosts/regex)
# Real-Debrid: https://api.real-debrid.com/rest/1.0/hosts/domains (+ /hosts/regex)
DEBRID_HOSTS_SYNC_INTERVAL_MS=3600000

# Per-source sync intervals (ms). 0 = disabled.
MINERVA_SYNC_INTERVAL_MS=21600000
IA_SYNC_INTERVAL_MS=21600000
FITGIRL_SYNC_INTERVAL_MS=21600000
DLPSGAME_SYNC_INTERVAL_MS=21600000
RROMS_SYNC_INTERVAL_MS=21600000

# Per-source ingest concurrency (bounded workers per source)
MINERVA_INGEST_CONCURRENCY=6
IA_INGEST_CONCURRENCY=6
FITGIRL_INGEST_CONCURRENCY=4
DLPSGAME_INGEST_CONCURRENCY=4
RROMS_INGEST_CONCURRENCY=6

# CORS allowlist for the frontend (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3010

# IP allowlist (comma-separated CIDRs; empty = allow all)
IP_ALLOWLIST=